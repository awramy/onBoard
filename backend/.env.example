# === Backend onBoard — переменные окружения ===
# Скопируйте в .env и подставьте свои значения.

# ---- Обязательные ----

# PostgreSQL (Prisma: миграции, seed, runtime).
# Локальная разработка при docker-compose из корня репо:
DATABASE_URL="postgresql://onboard:onboard_secret@localhost:5432/onboard"

# Секрет для подписи JWT (любая длинная случайная строка).
JWT_SECRET="your-super-secret-key-change-in-production"

# ---- Опциональные ----

# Срок жизни access token в секундах (по умолчанию 3600 = 1 час).
JWT_EXPIRATION=3600

# Порт HTTP-сервера (по умолчанию 3000).
PORT=3000

# API key для Gemini Developer API.
GEMINI_API_KEY=""

# Модель Gemini по умолчанию.
GEMINI_MODEL="gemini-2.5-flash"

# Опциональный override base URL для Gemini.
# Используйте, если поднимаете relay/совместимый upstream endpoint.
GEMINI_BASE_URL=""

# Явный upstream proxy для Gemini через undici global dispatcher.
# Пример: http://user:pass@proxy.example.com:8888
GEMINI_PROXY_URL=""

# Предпочитать IPv4, чтобы уменьшить вероятность IPv6 leakage мимо VPN/proxy.
GEMINI_FORCE_IPV4=false

# API key для OpenAI provider.
OPENAI_API_KEY=""

# Модель OpenAI по умолчанию.
OPENAI_MODEL="gpt-5-nano"
