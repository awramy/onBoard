# === Backend onBoard — переменные окружения ===
# Скопируйте в .env и подставьте свои значения.

# ---- Обязательные ----

# PostgreSQL (Prisma: миграции, seed, runtime).
# Локальная разработка при docker-compose из корня репо:
DATABASE_URL="postgresql://onboard:onboard_secret@localhost:5432/onboard"

# Секрет для подписи JWT (любая длинная случайная строка).
JWT_SECRET="your-super-secret-key-change-in-production"

# ---- Опциональные ----

# Срок жизни access token в секундах (по умолчанию 3600 = 1 час).
JWT_EXPIRATION=3600

# Порт HTTP-сервера (по умолчанию 3000).
PORT=3000
